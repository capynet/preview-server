#!/bin/bash

## Description: Push database and/or files to preview server
## Usage: push-to-preview-server [--db] [--files] [--include-heavy-files] [--max-file-size=SIZE]
## Example: "ddev push-to-preview-server" or "ddev push-to-preview-server --db --max-file-size=50M"

set -e

# Configuration
PREVIEW_SERVER="root@65.108.243.53"
PROJECT_NAME="drupal-test"
DB_DEST="/backups/${PROJECT_NAME}-base.sql.gz"
FILES_DEST="/backups/${PROJECT_NAME}-files.tar.gz"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Parse arguments
PUSH_DB=false
PUSH_FILES=false
INCLUDE_HEAVY_FILES=false
MAX_FILE_SIZE="20M"  # Default: files larger than 20MB are considered "heavy"

if [ $# -eq 0 ]; then
  # No arguments: push both
  PUSH_DB=true
  PUSH_FILES=true
else
  # Parse flags
  for arg in "$@"; do
    case $arg in
      --db)
        PUSH_DB=true
        ;;
      --files)
        PUSH_FILES=true
        ;;
      --include-heavy-files)
        INCLUDE_HEAVY_FILES=true
        ;;
      --max-file-size=*)
        MAX_FILE_SIZE="${arg#*=}"
        # Validate format (must end with K, M, or G)
        if ! [[ "$MAX_FILE_SIZE" =~ ^[0-9]+[KMG]$ ]]; then
          echo -e "${RED}Error: Invalid --max-file-size format: '$MAX_FILE_SIZE'${NC}"
          echo -e "Expected format: NUMBER + K/M/G (e.g., 50M, 100M, 1G)"
          exit 1
        fi
        ;;
      *)
        echo -e "${RED}Error: Unknown flag '$arg'${NC}"
        echo -e "Usage: ddev push-to-preview-server [--db] [--files] [--include-heavy-files] [--max-file-size=SIZE]"
        exit 1
        ;;
    esac
  done
fi

echo ""
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo -e "${BLUE}  Push to Preview Server${NC}"
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo ""

# Check if DDEV is running
if ! ddev describe >/dev/null 2>&1; then
  echo -e "${RED}Error: DDEV is not running. Start it with 'ddev start'${NC}"
  exit 1
fi

# Show what will be uploaded
echo -e "${CYAN}You are about to push an UPDATED version to ${PREVIEW_SERVER}:${NC}"
echo ""

if [ "$PUSH_DB" = true ]; then
  echo -e "  ${GREEN}✓${NC} Database  → ${DB_DEST}"
  echo -e "      This will replace the current base database."
  echo -e "      ${YELLOW}All NEW preview environments will use this version.${NC}"
fi

if [ "$PUSH_FILES" = true ]; then
  echo -e "  ${GREEN}✓${NC} Files     → ${FILES_DEST}"
  echo -e "      This will replace the current files archive."
  if [ "$INCLUDE_HEAVY_FILES" = false ]; then
    echo -e "      ${YELLOW}Excludes: cache dirs (css/js/styles/php/tmp) + files > ${MAX_FILE_SIZE}${NC}"
  else
    echo -e "      ${CYAN}Includes: ALL files (--include-heavy-files enabled)${NC}"
  fi
  echo -e "      ${YELLOW}All NEW preview environments will use this version.${NC}"
fi

echo ""
echo -e "${CYAN}Safety features:${NC}"
echo -e "  • Files uploaded to temporary location first"
echo -e "  • Atomic replacement (no corruption risk)"
echo -e "  • Waits if any preview deployment is in progress"
echo -e "  • Existing previews are NOT affected"
echo ""

# Ask for confirmation (default: Yes)
read -p "$(echo -e ${YELLOW}Do you want to continue? [Y/n]:${NC} )" -n 1 -r
echo
# If empty (just Enter) or Y/y, continue. If N/n, abort.
if [[ $REPLY =~ ^[Nn]$ ]]; then
  echo -e "${RED}Aborted.${NC}"
  exit 1
fi

echo ""
echo -e "${GREEN}Starting upload process...${NC}"
echo ""

# Temporary directory
TMP_DIR=$(mktemp -d)
trap "rm -rf $TMP_DIR" EXIT

UPLOADED_FILES=()

# Export and upload database
if [ "$PUSH_DB" = true ]; then
  echo -e "${BLUE}[DB 1/3] Exporting database...${NC}"
  DB_FILE="$TMP_DIR/${PROJECT_NAME}-base.sql.gz"
  ddev export-db --gzip --file="$DB_FILE"
  DB_SIZE=$(du -h "$DB_FILE" | cut -f1)
  echo -e "${GREEN}         ✓ Database exported (${DB_SIZE})${NC}"
  echo ""

  echo -e "${BLUE}[DB 2/3] Uploading to temporary location...${NC}"
  rsync -avz --progress "$DB_FILE" "${PREVIEW_SERVER}:${DB_DEST}.tmp"
  echo -e "${GREEN}         ✓ Uploaded to ${DB_DEST}.tmp${NC}"
  echo ""

  UPLOADED_FILES+=("db")
fi

# Compress and upload files directory
if [ "$PUSH_FILES" = true ]; then
  echo -e "${BLUE}[FILES 1/3] Compressing files directory...${NC}"
  FILES_FILE="$TMP_DIR/${PROJECT_NAME}-files.tar.gz"

  if [ -d "web/sites/default/files" ]; then
    # Build tar exclusions for cache directories
    TAR_EXCLUDES="--exclude=css --exclude=js --exclude=styles --exclude=php --exclude=tmp"

    # Count files before exclusions
    TOTAL_FILES=$(find web/sites/default/files -type f | wc -l)

    # If not including heavy files, create exclusion list
    if [ "$INCLUDE_HEAVY_FILES" = false ]; then
      echo -e "            ${YELLOW}Excluding files > ${MAX_FILE_SIZE} and cache directories...${NC}"
      EXCLUDE_FILE="$TMP_DIR/exclude-list.txt"

      # Find files larger than MAX_FILE_SIZE
      find web/sites/default/files -type f -size +${MAX_FILE_SIZE} > "$EXCLUDE_FILE" 2>/dev/null || true

      HEAVY_COUNT=$(wc -l < "$EXCLUDE_FILE")
      if [ "$HEAVY_COUNT" -gt 0 ]; then
        echo -e "            Found ${HEAVY_COUNT} files > ${MAX_FILE_SIZE} (will be excluded)"
        # Convert paths to relative for tar
        sed -i 's|web/sites/default/files/||' "$EXCLUDE_FILE"
        TAR_EXCLUDES="$TAR_EXCLUDES --exclude-from=$EXCLUDE_FILE"
      fi
    else
      echo -e "            ${CYAN}Including all files (--include-heavy-files enabled)${NC}"
    fi

    echo -e "            Compressing ${TOTAL_FILES} files..."
    tar -czf "$FILES_FILE" -C web/sites/default/files $TAR_EXCLUDES . 2>/dev/null
    FILES_SIZE=$(du -h "$FILES_FILE" | cut -f1)
    echo -e "${GREEN}            ✓ Files compressed (${FILES_SIZE})${NC}"
  else
    echo -e "${YELLOW}            ⚠ Files directory not found, creating empty archive...${NC}"
    touch "$FILES_FILE"
    FILES_SIZE="0"
  fi
  echo ""

  echo -e "${BLUE}[FILES 2/3] Uploading to temporary location...${NC}"
  rsync -avz --progress "$FILES_FILE" "${PREVIEW_SERVER}:${FILES_DEST}.tmp"
  echo -e "${GREEN}            ✓ Uploaded to ${FILES_DEST}.tmp${NC}"
  echo ""

  UPLOADED_FILES+=("files")
fi

# Create atomic replacement script on server
echo -e "${BLUE}[FINAL] Replacing files atomically on server...${NC}"
echo -e "        ${YELLOW}Waiting for any active deployments to finish...${NC}"

REPLACE_SCRIPT=$(cat <<'EOFSCRIPT'
#!/bin/bash
set -e

DB_FILE="$1"
FILES_FILE="$2"
PUSH_DB="$3"
PUSH_FILES="$4"

LOCK_DIR="/var/lock/preview-deployments"
LOCK_FILE="$LOCK_DIR/base-files.lock"

# Create lock directory if it doesn't exist
mkdir -p "$LOCK_DIR"

# Function to check if any deployment is running
check_deployments() {
  # Check for any active deployment locks
  if ls $LOCK_DIR/deploy-*.lock 2>/dev/null | grep -q .; then
    return 1  # Deployments are running
  fi
  return 0  # No deployments
}

# Wait for active deployments to finish
echo "Checking for active deployments..."
MAX_WAIT=300  # 5 minutes max
WAITED=0
while ! check_deployments; do
  if [ $WAITED -ge $MAX_WAIT ]; then
    echo "ERROR: Timeout waiting for deployments to finish"
    exit 1
  fi
  echo "  ⏳ Active deployment detected, waiting... (${WAITED}s)"
  sleep 5
  WAITED=$((WAITED + 5))
done

echo "  ✓ No active deployments"

# Acquire lock for base files update
echo "Acquiring lock for base files update..."
if ! mkdir "$LOCK_FILE" 2>/dev/null; then
  echo "ERROR: Another base files update is in progress"
  exit 1
fi
trap "rmdir $LOCK_FILE 2>/dev/null || true" EXIT

# Atomic replacement
if [ "$PUSH_DB" = "true" ] && [ -f "${DB_FILE}.tmp" ]; then
  echo "Replacing database..."
  mv -f "${DB_FILE}.tmp" "$DB_FILE"
  chown gitlab-runner:gitlab-runner "$DB_FILE"
  echo "  ✓ Database replaced: $DB_FILE"
fi

if [ "$PUSH_FILES" = "true" ] && [ -f "${FILES_FILE}.tmp" ]; then
  echo "Replacing files archive..."
  mv -f "${FILES_FILE}.tmp" "$FILES_FILE"
  chown gitlab-runner:gitlab-runner "$FILES_FILE"
  echo "  ✓ Files archive replaced: $FILES_FILE"
fi

echo "✓ All files replaced successfully with correct permissions"
EOFSCRIPT
)

# Execute replacement script on server
ssh "$PREVIEW_SERVER" "bash -s -- \"$DB_DEST\" \"$FILES_DEST\" \"$PUSH_DB\" \"$PUSH_FILES\"" <<EOF
$REPLACE_SCRIPT
EOF

echo ""

# Summary
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}✓ Upload completed successfully!${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "${BLUE}Updated files on server:${NC}"

if [ "$PUSH_DB" = true ]; then
  echo -e "  ${GREEN}✓${NC} Database: ${DB_DEST} (${DB_SIZE})"
fi

if [ "$PUSH_FILES" = true ]; then
  echo -e "  ${GREEN}✓${NC} Files:    ${FILES_DEST} (${FILES_SIZE})"
fi

echo ""
echo -e "${YELLOW}Next NEW preview environments will use these updated files.${NC}"
echo -e "${CYAN}Existing preview environments are not affected.${NC}"
echo ""
