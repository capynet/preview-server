# Preview Manager Backend Environment Variables

# Database
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@localhost:5432/{{ postgres_db }}

# API Settings
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=2

# CORS Settings (allow dashboard domain)
CORS_ORIGINS=https://{{ domain }},https://preview-mr.vercel.app

# Preview Settings
PREVIEWS_BASE_PATH=/var/www/previews
DDEV_ROUTER_NAME=ddev-router

# Logging
LOG_LEVEL=INFO
