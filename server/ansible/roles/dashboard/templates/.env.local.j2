# Next.js server configuration
HOSTNAME=0.0.0.0
PORT=3000

# Preview Manager API URL
# API_URL: For server-side calls (from Next.js container)
# Using public IP because host.docker.internal doesn't work on Linux
API_URL=http://{{ ansible_host }}:8000

# NEXT_PUBLIC_API_URL: For client-side calls (from browser)
# This must be the public URL accessible from the user's browser
NEXT_PUBLIC_API_URL=http://{{ ansible_host }}:8000
