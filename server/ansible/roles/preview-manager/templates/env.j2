# Preview Manager Configuration
# Generated by Ansible - {{ ansible_date_time.iso8601 }}

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Previews Base Path
PREVIEWS_BASE_PATH=/var/www/previews

# GitLab Integration
GITLAB_URL={{ gitlab_url }}
GITLAB_GROUP_NAME={{ gitlab_group_name }}

# Auth
SECRET_KEY={{ secret_key }}
GITLAB_OAUTH_CLIENT_ID={{ gitlab_oauth_client_id }}
GITLAB_OAUTH_CLIENT_SECRET={{ gitlab_oauth_client_secret }}
GOOGLE_OAUTH_CLIENT_ID={{ google_oauth_client_id | default('') }}
GOOGLE_OAUTH_CLIENT_SECRET={{ google_oauth_client_secret | default('') }}
AUTH_DB_PATH={{ auth_db_path | default('/var/www/preview-manager/auth.db') }}
ALLOWED_EMAIL_DOMAINS={{ allowed_email_domains | default('') }}
FRONTEND_URL={{ frontend_url | default('https://preview-mr.vercel.app') }}

# GitLab Connect OAuth (API scope for previews)
GITLAB_CONNECT_CLIENT_ID={{ gitlab_connect_client_id | default('') }}
GITLAB_CONNECT_CLIENT_SECRET={{ gitlab_connect_client_secret | default('') }}

# GitLab Webhooks
GITLAB_WEBHOOK_SECRET={{ gitlab_webhook_secret }}

# Resend (email invitations)
RESEND_API_KEY={{ resend_api_key | default('') }}
