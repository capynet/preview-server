# Preview Manager Configuration
# This file is managed by Ansible - changes will be overwritten

# Database Configuration
DATABASE_URL=postgresql+asyncpg://{{ postgresql_user }}:{{ postgresql_password }}@localhost:{{ postgresql_port }}/{{ postgresql_database }}
DATABASE_POOL_SIZE={{ postgresql_max_connections // 5 }}
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Preview Settings
PREVIEWS_BASE_PATH=/var/www/previews
INACTIVITY_THRESHOLD_MINUTES=15

# Resource Monitoring
MAX_MEMORY_PERCENT=85.0
MAX_CPU_PERCENT=90.0
CHECK_INTERVAL_SECONDS=60

# Traefik
TRAEFIK_CONTAINER_NAME=traefik-traefik-1

# DDEV
DDEV_BINARY=/usr/bin/ddev
